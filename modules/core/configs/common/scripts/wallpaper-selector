#!/usr/bin/env bash
# wallpicker - Simple wallpaper picker using swiv
# Ctrl-x Return = apply wallpaper, Ctrl-x d = delete

WALLPAPER_DIR="$HOME/Wallpapers"
CURRENT_LINK="$HOME/.current_wallpaper"

mkdir -p "$WALLPAPER_DIR"
cd "$WALLPAPER_DIR" || exit 1

files=(*.jpg *.jpeg *.png *.webp *.bmp)
[ -f "${files[0]}" ] || { notify-send "Wallpaper" "No wallpapers found"; exit 1; }

mkdir -p "$HOME/.config/swiv/exec"

cat > "$HOME/.config/swiv/exec/key-handler" << 'KEYHANDLER'
#!/usr/bin/env bash

WALLPAPER_DIR="$HOME/Wallpapers"
CURRENT_LINK="$HOME/.current_wallpaper"

while read -r file; do
    case "$1" in
        "Return")
            pkill swaybg 2>/dev/null || true
            ln -sf "$file" "$CURRENT_LINK"
            swaybg -m fill -i "$file" &
            notify-send "Wallpaper Applied" "$(basename "$file")"
            ;;
        "d")
            rm -f "$file"
            notify-send "Wallpaper Deleted" "$(basename "$file")"
            ;;
    esac
done
KEYHANDLER
chmod +x "$HOME/.config/swiv/exec/key-handler"

swiv -t -B "#1e1e1e" -C "#3e3e3e" -- "${files[@]}"
